setenv FRIENDLY_NAME "CHEarnMoney_arz"
client
dev tun
proto udp
remote s7.nimbaha.info
port 6565
nobind
resolv-retry infinite
persist-key
persist-tun
tls-client
remote-cert-tls server
verb 4
cipher AES-128-CBC
auth SHA1
auth-user-pass
redirect-gateway def1
dhcp-option DNS 9.9.9.9



