client
dev tun
remote ping.bh.ae-static.online 528 udp
remote ping.bh.ae-static.online 528 tcp
remote ping.bh.ae-static.online 423 udp
remote ping.bh.ae-static.online 3333 tcp
resolv-retry infinite
nobind
persist-key
persist-tun
remote-cert-tls server
auth SHA1
cipher AES-256-CBC
redirect-gateway 
ignore-unknown-option block-outside-dns
block-outside-dns
pull-filter ignore "ifconfig-ipv6"
pull-filter ignore "route-ipv6"
verb 3
auth-user-pass
#keepalive 10 120
